{
  "allowCustomDataForDataTypeAny": true,
  "allowErrorForDataTypeAny": true,
  "functions": [
    {
      "id": "PRICE",
      "name": "PRICE",
      "description": "Gets the latest OilPriceAPI price for a commodity code.",
      "helpUrl": "https://docs.oilpriceapi.com",
      "parameters": [
        {
          "name": "code",
          "description": "Commodity code, for example BRENT_CRUDE_USD.",
          "type": "string",
          "optional": false
        }
      ],
      "result": {
        "type": "any",
        "dimensionality": "scalar"
      }
    },
    {
      "id": "GET",
      "name": "GET",
      "description": "Calls a supported OilPriceAPI GET endpoint and returns a table.",
      "helpUrl": "https://docs.oilpriceapi.com",
      "parameters": [
        {
          "name": "path",
          "description": "Supported API path, for example /v1/prices/latest.",
          "type": "string",
          "optional": false
        },
        {
          "name": "query",
          "description": "Query string, for example by_code=BRENT_CRUDE_USD.",
          "type": "string",
          "optional": true
        }
      ],
      "result": {
        "type": "string",
        "dimensionality": "matrix"
      }
    },
    {
      "id": "CODES",
      "name": "CODES",
      "description": "Returns available OilPriceAPI commodity codes when supported by the API key.",
      "helpUrl": "https://docs.oilpriceapi.com",
      "parameters": [],
      "result": {
        "type": "string",
        "dimensionality": "matrix"
      }
    }
  ]
}
